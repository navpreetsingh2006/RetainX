generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  company      String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  datasets     Dataset[]
}

model Dataset {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  name        String
  description String?
  dataJson    Json
  createdAt   DateTime @default(now())
  charts      Chart[]
}

model Chart {
  id         Int      @id @default(autoincrement())
  dataset    Dataset  @relation(fields: [datasetId], references: [id])
  datasetId  Int
  type       String   // e.g., line, bar, pie
  configJson Json     // chart configuration generated by ML model
  imageUrl   String?
  createdAt  DateTime @default(now())
}
